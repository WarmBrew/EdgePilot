# Edge Device Management Platform - Frontend Environment Variables
# Copy this file to .env.local and fill in the values
# Vite automatically loads .env.local during development

# API Base URL (backend server address)
VITE_API_BASE_URL=http://localhost:8080

# WebSocket Base URL (for real-time communication)
VITE_WS_BASE_URL=ws://localhost:8080

# Application Title (displayed in browser tab and header)
VITE_APP_TITLE=Edge Platform
