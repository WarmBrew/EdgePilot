# ============================================
# Edge Device Management Platform - Environment Variables
# ============================================
# Copy this file to .env and fill in the values
# Never commit .env files to version control!
# ============================================

# -------------------------------------------
# Application Settings
# -------------------------------------------
APP_NAME=edge-platform
APP_ENV=development
APP_DEBUG=true
APP_PORT=8080
APP_SECRET=your_app_secret_key_here_change_in_production

# -------------------------------------------
# Database Configuration (PostgreSQL)
# -------------------------------------------
DB_HOST=localhost
DB_PORT=5432
DB_NAME=edge_platform
DB_USER=postgres
DB_PASSWORD=your_secure_password_here
DB_SSLMODE=disable
DB_MAX_OPEN_CONNS=25
DB_MAX_IDLE_CONNS=5

# -------------------------------------------
# Redis Configuration
# -------------------------------------------
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=
REDIS_DB=0

# -------------------------------------------
# JWT Authentication
# -------------------------------------------
JWT_SECRET=your_jwt_secret_key_here_change_in_production
JWT_EXPIRE=24h
JWT_REFRESH_EXPIRE=168h

# -------------------------------------------
# API Configuration
# -------------------------------------------
API_RATE_LIMIT=100
API_CORS_ORIGINS=http://localhost:5173,http://localhost:3000

# -------------------------------------------
# Encryption
# -------------------------------------------
ENCRYPTION_KEY=your_32_byte_encryption_key_here

# -------------------------------------------
# Logging
# -------------------------------------------
LOG_LEVEL=info
LOG_FORMAT=json

# -------------------------------------------
# Agent Configuration
# -------------------------------------------
AGENT_TOKEN_SECRET=your_agent_token_secret_here
AGENT_HEARTBEAT_INTERVAL=30
AGENT_SYNC_INTERVAL=300
AGENT_MAX_BUFFER_SIZE=1000

# -------------------------------------------
# File Storage
# -------------------------------------------
STORAGE_TYPE=local
STORAGE_PATH=./storage
STORAGE_MAX_SIZE_MB=100

# -------------------------------------------
# Monitoring & Metrics
# -------------------------------------------
METRICS_ENABLED=true
METRICS_PORT=9090
TRACING_ENABLED=false
TRACING_ENDPOINT=

# -------------------------------------------
# Email Configuration (Optional)
# -------------------------------------------
SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_USER=noreply@example.com
SMTP_PASSWORD=your_smtp_password_here
SMTP_FROM=noreply@example.com

# -------------------------------------------
# Audit Logging
# -------------------------------------------
AUDIT_ENABLED=true
AUDIT_QUEUE_SIZE=10000
AUDIT_BATCH_SIZE=100

# -------------------------------------------
# Third-party Integrations (Optional)
# -------------------------------------------
# Add any third-party API keys or endpoints here
